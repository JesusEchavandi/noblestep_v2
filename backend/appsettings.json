{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/noblestep-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "fileSizeLimitBytes": 10485760,
          "rollOnFileSizeLimit": true,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {CorrelationId} {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=noblestep_db;User=root;Password=;"
  },
  "ApiConsulta": {
    "Token": "DEV_TOKEN_PLACEHOLDER"
  },
  "JwtSettings": {
    "SecretKey": "DEV-SECRET-KEY-CHANGE-IN-PRODUCTION-MIN-32-CHARS!!",
    "Issuer": "NobleStepApi",
    "Audience": "NobleStepClient",
    "ExpirationMinutes": 1440
  },
  "Email": {
    "FromEmail": "noblestep@gmail.com",
    "FromName": "NobleStep Shop",
    "SmtpHost": "smtp.gmail.com",
    "SmtpPort": "587",
    "SmtpUsername": "noblestep@gmail.com",
    "SmtpPassword": "DEV_SMTP_PASSWORD_PLACEHOLDER",
    "SmtpTimeoutSeconds": "10"
  },
  "App": {
    "FrontendUrl": "http://localhost:4201"
  }
}
